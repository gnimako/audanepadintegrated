@model LoginViewModel
<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>AUDA-NEPAD Data Platform</title>
        <meta name="description" content="" />
        <meta name="keywords" content="" />
        <meta name="author" content="Themesdesign" />

        <!-- App favicon -->
       
        <link rel="shortcut icon" type="image/png" sizes="16x16"  href="~/frontpage/images/favicon.png">

        <!-- Bootstrap core CSS -->
        <link rel="stylesheet" href="~/frontpage/css/bootstrap.min.css" type="text/css">

        <!-- Material Icon -->
        <link rel="stylesheet" type="text/css" href="~/frontpage/css/materialdesignicons.min.css" />

        <!-- owl carousel -->
        <link rel="stylesheet" type="text/css" href="~/frontpage/css/owl.carousel.min.css" />
        <link rel="stylesheet" type="text/css" href="~/frontpage/css/owl.theme.default.min.css" />

        <!-- Custom  sCss -->
        <link rel="stylesheet" type="text/css" href="~/frontpage/css/style.css" />

        <script src="~/lib/jquery/jquery.js"></script>
        <script src="~/lib/jquery-validate/jquery.validate.js"></script>
        <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.js"></script>
        <script src="~/lib/bootstrap/js/bootstrap.js"></script>

    </head>

    <body>



        <nav class="navbar navbar-expand-lg fixed-top navbar-custom sticky sticky-dark">
            <div class="container">
                <!-- LOGO -->
                <a class="logo text-uppercase" asp-controller="home" asp-action="index">
                    <img src="~/frontpage/images/logo-dark.png" alt="" class="logo-dark" height="70" />
                </a>

            </div>
        </nav>

        
        <!-- Hero section Start -->
        <section class="hero-section" id="home" style="background: url('@Url.Content("~/frontpage/images/bg-1.png")') center center;">
            <div class="container">
                <div class="row justify-content-center">
                    <div class="col-lg-6">
                        <div class="hero-wrapper mb-4">
                                	@RenderBody()
                        </div>
                        
                    </div>

                    <div class="col-lg-4 offset-lg-2" style="height: 460px; width: 450px">
                        <div id="focusdiv" class="card mx-auto p-4 rounded mt-5 mt-lg-0" style="border-radius: 1.25rem!important;">
                            <div class="text-center">
                                   @* <p class="text-muted mb-2 font-13 text-uppercase">AUDA-NEPAD</p> *@
                                       <img src="~/frontpage/images/loginlock.png" alt="" height="50px" width="50px">
                                       <br \>
                                       <br \>

                                <h5 class="form-title mb-4" style="font-family: Faktslab;">Login to the System</h5>
                            </div>
                            <form class="registration-form" id="loginform" method="post">
                                <div asp-validation-summary="All" class="text-danger"></div>
                                <div class="form-group mb-4">
                                    <input id="Email" asp-for="Email" class="form-control" placeholder="Email" style="outline: 0; border-width: 0 0 1px; border-color: #a0a9b1; border-radius: 0.0rem;">
                                     @* <span asp-validation-for="Email" class="text-danger"></span> *@
                                </div>
                                <div class="form-group mb-3">
                                    <input asp-for="Password" class="form-control"  placeholder="Password" style="outline: 0; border-width: 0 0 1px; border-color: #a0a9b1; border-radius: 0.0rem;">
                                    @* <span asp-validation-for="Password" class="text-danger"></span> *@
                                </div>
                                  <br \>
                                 <button type="submit" class="btn btn-primary btn-block btn-sm">Login <i class="mdi mdi-telegram ml-2"></i></button>
                                    <br \>
                                    <br \>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- end row -->
            </div>
            <!-- end container -->
        </section>


        <!-- Footer alt start -->

        <!-- Footer alt start -->

        <!-- Javascript -->
        <script src="~/frontpage/js/jquery.min.js"></script>
        <script src="~/frontpage/js/bootstrap.bundle.min.js"></script>
        <script src="~/frontpage/js/jquery.easing.min.js"></script>
        <script src="~/frontpage/js/scrollspy.min.js"></script>
        <script src="~/frontpage/js/feather.min.js"></script>

        <!-- owl carousel -->
        <script src="~/frontpage/js/owl.carousel.min.js"></script>

        <!-- app js -->
        <script src="~/frontpage/js/app.js"></script>

<style> 

    .form-control::placeholder {
        color: #a0a9b1;
        opacity: 1;
    }


    .form-control:-ms-input-placeholder { /* Internet Explorer 10-11 */
        color: #a0a9b1;
    }

    .form-control::-ms-input-placeholder { /* Microsoft Edge */
        color:#a0a9b1;
    }
    .form-control:focus {
        border-color: #2f55d4;
    }
</style> 

<script>


    window.onload = function() {
        document.getElementById("Email").focus();
    };

    $('#Email').on('focus', function() {
        document.body.scrollTop = $(this).offset().top;
    });
</script>
    </body>

</html>