@model EmployeeViewModel
@{
    ViewBag.Title = "AUDA-NEPAD Integrated Planning System";
    Layout = "_NEPADStaffLayout2";

}

<h1>Current Workplan</h1>
<div class="separator mb-5"></div>

                <div class="col-12 mb-4">
         
                    <div class="card mb-4" style="padding: 1.75rem;">
                        <form>
                              <div class="form-group row">
                                    <label for="inputEmail3" class="col-sm-2 col-form-label" style="font-size: 1.15rem;">Year</label>
                                    <div class="col-sm-10" style="font-size: 1.15rem; color: #145388; padding-top: calc(.375rem + 1px); padding-bottom: calc(.375rem + 1px); ">
                                        @Model.CurrentYear
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="inputEmail3" class="col-sm-2 col-form-label" style="font-size: 1.15rem;">Directorate</label>
                                    <div class="col-sm-10" style="font-size: 1.15rem; color: #145388; padding-top: calc(.375rem + 1px); padding-bottom: calc(.375rem + 1px); ">
                                        @Model.DirectorateName
                                    </div>
                                </div>
                                <div class="form-group row">
                                    <label for="inputEmail3" class="col-sm-2 col-form-label" style="font-size: 1.15rem;">Division</label>
                                    <div class="col-sm-10" style="font-size: 1.15rem; color: #145388;  ">
                                                    @(Html.Kendo().DropDownList()
                                                                  .Name("Directorate_Id")
                                                                  .HtmlAttributes(new { style = "width:100%" })
                                                                  .OptionLabel("Select Directorate...")
                                                                  .DataTextField("DropDown_Name")
                                                                  .DataValueField("DropDown_IntId")
                                                                  .DataSource(source =>
                                                                  {
                                                                      source.Read(read =>
                                                                      {
                                                                          read.Action("GetAllTransDirectorate", "Admin");
                                                                      });
                                                                  })
                                                                 // .SelectedIndex(Model.Directorate_Id)
                                                    )

                                    </div>
                                </div>
                        </form>




                    </div>
                </div>

