



@model WP_OutputRiskProfileVMWindow

<form id="addform">

    <input hidden asp-for="Employee_IdORVMMain" class="k-textbox" style="width:100%" value="@Model.Employee_IdORVMMain">
    <input hidden asp-for="Transaction_IdORVMMain" class="k-textbox" style="width:100%" value="@Model.Transaction_IdORVMMain">
    <input hidden asp-for="FiscalYear_IdORVMMain" class="k-textbox" style="width:100%" value="@Model.FiscalYear_IdORVMMain">
    <input hidden asp-for="Period_IdORVMMain" class="k-textbox" style="width:100%" value="@Model.Period_IdORVMMain">
    <input hidden asp-for="FisPeriodORVMMain" class="k-textbox" style="width:100%" value="@Model.FisPeriodORVMMain">
    <input hidden asp-for="Project_IdORVMMain" class="k-textbox" style="width:100%" value="@Model.Project_IdORVMMain">
    <input hidden asp-for="WPMainRecord_idORVMMain" class="k-textbox" style="width:100%" value="@Model.WPMainRecord_idORVMMain">
    
    <div class="form-body" style="padding: 1.25rem;">
           
            <h6 style="color:#807878">Brief Description of Risk</h6>
            @Html.TextAreaFor(model => model.WPRisk_DescriptionORVMMain, new { @class = "k-textbox", style = "width: 100%;", value="", rows="3"})
            <br />
            <br />

            <div class="div1">
                        <h6 style="color:#807878">Risk Category</h6>
                        @(Html.Kendo().DropDownListFor(model => model.WPCategory_IdORVMMain)
                            // .Name("Department_Id")
                            .HtmlAttributes(new { style = "width:90%", id = "WPCategory_IdORVMMain" })
                            .OptionLabel("Select...")
                            .DataTextField("DropDown_Name")
                            .DataValueField("DropDown_IntId")
                            .DataSource(source =>
                            {
                                source.Read(read =>
                                {
                                        read.Action("GetAllTransRiskCategories", "Admin");
                                    
                                })
                                .ServerFiltering(true);
                            })
                            
                        
                            //.SelectedIndex(Model.Department_Id)
                        )
                        <br />
                        <br />
                </div>

                <div class="div2">
                    <h6 style="color:#807878">Impact Level</h6>
                        @(Html.Kendo().DropDownListFor(model => model.WPRiskImpactLevel_IdORVMMain)
                            // .Name("Department_Id")
                            .HtmlAttributes(new { style = "width:100%", id = "WPRiskImpactLevel_IdORVMMain" })
                            .OptionLabel("Select...")
                            .DataTextField("DropDown_Name")
                            .DataValueField("DropDown_IntId")
                            .DataSource(source =>
                            {
                                source.Read(read =>
                                {
                                        read.Action("GetAllTransImpactLevels", "Admin");
                                    
                                })
                                .ServerFiltering(true);
                            })
                            
                        
                            //.SelectedIndex(Model.Department_Id)
                        )
                        <br />
                        <br />
                </div>
  



            <div class="div1">
                    <h6 style="color:#807878">Probability of Occurrence</h6>
                        @(Html.Kendo().DropDownListFor(model => model.WPRiskProbability_IdORVMMain)
                            // .Name("Department_Id")
                            .HtmlAttributes(new { style = "width:90%", id = "WPRiskProbability_IdORVMMain" })
                            .OptionLabel("Select...")
                            .DataTextField("DropDown_Name")
                            .DataValueField("DropDown_IntId")
                            .DataSource(source =>
                            {
                                source.Read(read =>
                                {
                                        read.Action("GetAllTransProbabilities", "Admin");
                                    
                                })
                                .ServerFiltering(true);
                            })
                            
                        
                            //.SelectedIndex(Model.Department_Id)
                        )
                        <br />
                        <br />
            </div>
            <div class="div2">
                 <h6 style="color:#807878">Frequency of Reporting</h6>
                        @(Html.Kendo().DropDownListFor(model => model.WPFrequencyOfReporting_IdORVMMain)
                            // .Name("Department_Id")
                            .HtmlAttributes(new { style = "width:100%", id = "WPFrequencyOfReporting_IdORVMMain" })
                            .OptionLabel("Select...")
                            .DataTextField("DropDown_Name")
                            .DataValueField("DropDown_IntId")
                            .DataSource(source =>
                            {
                                source.Read(read =>
                                {
                                        read.Action("GetAllTransRiskReportingFreq", "Admin");
                                    
                                })
                                .ServerFiltering(true);
                            })
                            
                        
                            //.SelectedIndex(Model.Department_Id)
                        )
                        <br />
                        <br />
            </div>


            


             <h6 style="color:#807878"><span id="costinfo">Risk Cost (in USD)</span></h6>
            @Html.TextBoxFor(model => model.WPRiskCostORVMMain, new { @class = "k-textbox",  style = "width: 100%;", value=""})
        
                <br />
                <br />

                <div class="div1">
                    <h6 style="color:#807878">Risk Owner</h6>
                        @(Html.Kendo().DropDownListFor(model => model.WPRiskOwner_IdORVMMain)
                            // .Name("Department_Id")
                            .HtmlAttributes(new { style = "width:90%", id = "WPRiskOwner_IdORVMMain" })
                            .OptionLabel("Select...")
                            .DataTextField("DropDown_Name")
                            .DataValueField("DropDown_IntId")
                            .DataSource(source =>
                            {
                                source.Read(read =>
                                {
                                        read.Action("GetAllEmployee", "Admin");
                                    
                                })
                                .ServerFiltering(true);
                            })
                            
                        
                            //.SelectedIndex(Model.Department_Id)
                        )
                        <br />
                        <br />
            </div>
            <div class="div2">
                 <h6 style="color:#807878">Risk Champion</h6>
                        @(Html.Kendo().DropDownListFor(model => model.WPRiskChampion_IdORVMMain)
                            // .Name("Department_Id")
                            .HtmlAttributes(new { style = "width:100%", id = "WPRiskChampion_IdORVMMain" })
                            .OptionLabel("Select...")
                            .DataTextField("DropDown_Name")
                            .DataValueField("DropDown_IntId")
                            .DataSource(source =>
                            {
                                source.Read(read =>
                                {
                                        read.Action("GetAllEmployee", "Admin");
                                    
                                })
                                .ServerFiltering(true);
                            })
                            
                        
                            //.SelectedIndex(Model.Department_Id)
                        )
                        <br />
                        <br />
            </div>




                <div><h6 style="color:#807878">Mitigation Measure(s)</h6></div>
                @Html.TextAreaFor(model => model.WPRisk_MitigationMeasuresORVMMain, new { @class = "k-textbox", style = "width: 100%;", value="", rows="3"})
                <br />
                <br />
      

                <div><h6 style="color:#807878">Additional Notes</h6></div>
                @Html.TextAreaFor(model => model.WPRisk_AdditionalNotesORVMMain, new { @class = "k-textbox", style = "width: 100%;", value="", rows="3"})
                <br />
                <br />

                <div id="targetDivStaffa_act" class="rssedStaffa_act">
                </div>
                <br />

                <div style="align-content:center; text-align:center">
                    <a class="k-button" id="btnSubmita_act">
                        <span class="k-icon k-i-save"></span> Save
                    </a>

                    <a class="k-button" id="btnCloseStaffa_act">
                        <span class="k-icon k-i-cancel"></span> Close
                    </a>
                </div>


    </div>





</form>







<script>
    
    $("#btnCloseStaffa_act").click(function () {
        $(".k-window-content").each(function () {
            $(this).data("kendoWindow").close();
        });
    });






$("#btnSubmita_act").click(function (e) {

    var gridid = $("#Transaction_IdORVMMain").val(); 

    var projid = $("#Project_IdORVMMain").val();  
    var fyear = $("#FiscalYear_IdORVMMain").val();  
    var fperiod = $("#Period_IdORVMMain").val();  
    var periodtxt = $("#FisPeriodORVMMain").val();  

    var riskdesc = $("#WPRisk_DescriptionORVMMain").val();  
    var riskcategory_id = $("#WPCategory_IdORVMMain").val(); 
    var riskimpactlevel_id = $("#WPRiskImpactLevel_IdORVMMain").val(); 
    var riskprobability_id = $("#WPRiskProbability_IdORVMMain").val(); 
    var riskreportingfreq_id = $("#WPFrequencyOfReporting_IdORVMMain").val(); 


    var risk_cost = $("#WPRiskCostORVMMain").val();  

    var riskowner_id = $("#WPRiskOwner_IdORVMMain").val(); 
    var riskchampion_id = $("#WPRiskChampion_IdORVMMain").val(); 

    var risk_mitigationmeasures = $("#WPRisk_MitigationMeasuresORVMMain").val();  
    var risk_additionalnotes = $("#WPRisk_AdditionalNotesORVMMain").val();


    




    if(riskdesc === "" && typeof riskdesc === "string")
    {
        $('#targetDivStaffa_act').empty();
        $('<span class="alert alert-warning" style="display: block;font-size: 100%">No Entry : Please describe the risk. </span>').appendTo('.rssedStaffa_act');
    }
    else if(riskcategory_id === "" && typeof riskcategory_id === "string")
    {
        $('#targetDivStaffa_act').empty();
        $('<span class="alert alert-warning" style="display: block;font-size: 100%">No Selection : Please select the risk category. </span>').appendTo('.rssedStaffa_act');
    }
    else if(riskimpactlevel_id === "" && typeof riskimpactlevel_id === "string")
    {
        $('#targetDivStaffa_act').empty();
        $('<span class="alert alert-warning" style="display: block;font-size: 100%">No Selection : Please select the risk impact level. </span>').appendTo('.rssedStaffa_act');
    }
    else if(riskprobability_id === "" && typeof riskprobability_id === "string")
    {
        $('#targetDivStaffa_act').empty();
        $('<span class="alert alert-warning" style="display: block;font-size: 100%">No Selection : Please select the probability of occurrence </span>').appendTo('.rssedStaffa_act');
    }
    else if(riskreportingfreq_id === "" && typeof riskreportingfreq_id === "string")
    {
        $('#targetDivStaffa_act').empty();
        $('<span class="alert alert-warning" style="display: block;font-size: 100%">No Selection : Please select the reporting frequency. </span>').appendTo('.rssedStaffa_act');
    }
    else if(risk_cost === "" && typeof risk_cost === "string")
    {
        $('#targetDivStaffa_act').empty();
        $('<span class="alert alert-warning" style="display: block;font-size: 100%">No Entry : Please provide risk cost. </span>').appendTo('.rssedStaffa_act');
    }
    else if(isNaN(risk_cost))
    {
        $('#targetDivStaffa_act').empty();
        $('<span class="alert alert-warning" style="display: block;font-size: 100%">Risk cost should be a number. </span>').appendTo('.rssedStaffa_act');
    }
    else if(riskowner_id === "" && typeof riskowner_id === "string")
    {
        $('#targetDivStaffa_act').empty();
        $('<span class="alert alert-warning" style="display: block;font-size: 100%">No Selection : Please select the risk owner. </span>').appendTo('.rssedStaffa_act');
    }
    else if(riskchampion_id === "" && typeof riskchampion_id === "string")
    {
        $('#targetDivStaffa_act').empty();
        $('<span class="alert alert-warning" style="display: block;font-size: 100%">No Selection : Please select the risk champion. </span>').appendTo('.rssedStaffa_act');
    }
    else
    {
        //Work on this...
        $.ajax({
                type: "POST",
                url: '/Admin/AddOutputRiskProfileNew',     //your action
                data: $('#addform').serialize(),   //your form name.it takes all the values of model
                dataType: 'json',
                success: function (result) {
                    var response = result.rtnmsg;
                    var remainfunds = result.remainfunds;


                    if (response == "success") {
                                $('#targetDivStaffa_act').empty();
                                $('<span class="alert alert-success" style="display: block;font-size: 100%">Success : Risk Profile Saved Successfully. </span>').appendTo('.rssedStaffa_act');


                                var childGrid = $('#gridriskprofilesub_'+gridid).data("kendoGrid");

                                childGrid.dataSource.transport.options.read.url = "/Admin/WP_OutputsSubRiskProfile_Read?output_transid=" + gridid;
                                childGrid.dataSource.read();
                                //childGrid.refresh();

                                var grid_outputproc = $("#grid_outputriskprofile").data("kendoGrid"); 
                                grid_outputproc.dataSource.transport.options.read.url = "/Admin/WP_Outputs_for_RiskProfile_Read?projid=" + projid + "&fyear=" + fyear + "&fperiod=" + fperiod + "&periodtxt=" + periodtxt;
                                grid_outputproc.dataSource.read();


                    }
                    else if (response == "insufficientfunds") {
                            $('#targetDivStaffa_act').empty();
                            $('<span class="alert alert-danger" style="display: block;font-size: 100%">Insufficient funds available for this output. Remaining Funds: $'+ remainfunds+' </span>').appendTo('.rssedStaffa_act');
                            //$('#targetDivStaffa').empty();
                    }
                    else if (response == "pkerror") {
                            $('#targetDivStaffa_act').empty();
                            $('<span class="alert alert-danger" style="display: block;font-size: 100%">Unable to Save. Risk Profile Already Exist. </span>').appendTo('.rssedStaffa_act');
                            //$('#targetDivStaffa').empty();
                    }
                    else if (response == "createerror") {
                            $('#targetDivStaffa_act').empty();
                            $('<span class="alert alert-danger" style="display: block;font-size: 100%">Error: Unable to save Risk Profile</span>').appendTo('.rssedStaffa_act');
                            //$('#targetDivStaffa').empty();
                    }
                    else if (response == "doesnotexist") {
                            $('#targetDivStaffa_act').empty();
                            $('<span class="alert alert-danger" style="display: block;font-size: 100%">No Record: Risk Profile does not exist</span>').appendTo('.rssedStaffa_act');
                            //$('#targetDivStaffa').empty();
                    }
                    else {
                            $('#targetDivStaffa_act').empty();
                            $('<span class="alert alert-danger" style="display: block;font-size: 100%">Unknown Error: Please try Again </span>').appendTo('.rssedStaffa_act');
                            //$('#targetDivStaffa').empty();
                    }

                },
                error: function (data) {
                        $('#targetDivStaffa_act').empty();
                        $('<span class="alert alert-danger" style="display: block;font-size: 100%">Error: Error Occurred whiles saving </span>').appendTo('.rssedStaffa_act');
                        //$('#targetDivStaffa').empty();
                }
            });


    }








        
    
    
    return false;
});






</script>


