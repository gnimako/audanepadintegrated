@model EmployeeViewModel
@{
    ViewBag.Title = "AUDA-NEPAD Integrated Planning System";
    Layout = "_NEPADStaffLayout2";

}


<link rel="stylesheet" href="~/nepadstaff1/css/vendor/smart_wizard.min.css" />
<link href="~/nepadstaff2/dist-assets/css/themes/dore.light.blue2.css" rel="stylesheet" />


<h1 style="font-family: Faktslab;">Manage Workplans</h1>

                <div class="separator-breadcrumb border-top"></div>


                <div class="row">
                    <div class="col-md-12">
                        <div class="card mb-5">
                            <div class="card-body">
                                <form id="addformmain">
                                <input hidden asp-for="IdentityUserId" class="k-textbox" style="width:100%" value="@Model.IdentityUserId">
                                <input hidden asp-for="Employee_Id" class="k-textbox" style="width:100%" value="@Model.Id">
                                <input hidden asp-for="WPMainRecordId" class="k-textbox" style="width:100%" value="@Model.WPMainRecordId">
                                <input hidden asp-for="Programme_Id" class="k-textbox" style="width:100%" value="@Model.Programme_Id">
                                <input hidden asp-for="Project_Id" class="k-textbox" style="width:100%" value="@Model.Project_Id">
                                <input hidden asp-for="FYear" class="k-textbox" style="width:100%" value="@Model.FYear">
                                <input hidden asp-for="FPeriod" class="k-textbox" style="width:100%" value="@Model.FPeriod">
                                <input hidden asp-for="Directorate_Id" class="k-textbox" style="width:100%" value="@Model.Directorate_Id">
                                <input hidden asp-for="Division_Id" class="k-textbox" style="width:100%" value="@Model.Division_Id">
                                    <div class="form-group row">
                                        <label class="col-sm-2 col-form-label" for="inputPassword3">Project</label>
                                        <div class="col-sm-10" style="padding-top: calc(0.375rem + 1px); padding-bottom: calc(0.375rem + 1px);">
                                           <b>@Model.Project_Name</b>
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <label class="col-sm-2 col-form-label" for="inputPassword3">Year</label>
                                        <div class="col-sm-10" style="padding-top: calc(0.375rem + 1px); padding-bottom: calc(0.375rem + 1px);">
                                            @Model.FisYear
                                        </div>
                                    </div>

                                    <div class="form-group row">
                                        <label class="col-sm-2 col-form-label" for="inputPassword3">Period</label>
                                        <div class="col-sm-10" style="padding-top: calc(0.375rem + 1px); padding-bottom: calc(0.375rem + 1px);">
                                            @Model.FisPeriod
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                       
                                        <div class="col-sm-10" style="padding-top: calc(0.375rem + 1px); padding-bottom: calc(0.375rem + 1px); color: #570b06">
                                           
                                            <span style="font-size: 14px; color: #1b406c;">Workplan Status</span>
                                            <div class="separator-breadcrumb border-top"></div>
                                          
                                     
                                               <div id="norecord" style="visibility: hidden;">No Record</div>
                                                
                                         
                                               <div  id="recordstatus" style="visibility: hidden;">
                                                   @(Html.Kendo().Stepper()
                                                        .Name("Timeline")
                                                        .Linear(false)
                                                        .Orientation(StepperOrientationType.Horizontal)
                                                        .Steps(s =>
                                                        {
                                                            s.Add().Label("Drafting Mode").Icon("track-changes-enable").Selected(true);
                                                            s.Add().Label("Approved").Icon("check-outline").Enabled(false);
                                                            s.Add().Label("Closed").Icon("lock").Enabled(false);
                                                        })
                                                    )
                                               </div>
                                                                                            
                                                                                            
                                            
                                          
                                        </div>
                                    </div>
                                   
                                </form>
                            </div>
                        </div>
                    </div>
                </div>






