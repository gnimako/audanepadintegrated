<script type="text/javascript">
 $("#btnAddMTP").click(function () {

 // e.preventDefault();
        var mtpid = $("#MTP_Id").val();  
        var projid = $("#Project_Id").val();  
        var fyear = $("#FYear").val();  
        var fperiod = $("#FPeriod").val();  
        var empid = $("#Employee_Id").val(); 


        var dialog = $('#dialog');
        var undo = $("#undo");

        function onClose() {
            undo.fadeIn();
        }

        if(mtpid === "" && typeof mtpid === "string")
        {
              dialog.kendoDialog({
                  width: "300px",
                  title: "No Selection",
                  closable: false,
                  modal: true,
                  content: "<p>Please select <strong>MTP Priority</strong><p>",
                  actions: [
                      { text: 'Cancel' }
                  ],
                  close: onClose
              });

              dialog.data("kendoDialog").open();
              undo.fadeOut();
        }
        else{
            $.ajax({
                type: "POST",
                url: '/Admin/AddWPMTPPriority',     //your action
                //data: $('#addformmain').serialize(),   //your form name.it takes all the values of model
                data: { "projid": projid, "fyear": fyear, "fperiod": fperiod, "mtpid": mtpid, "empid": empid},   //your form name.it takes all the values of model
                dataType: 'json',
                success: function (result) {
                    var response = result.rtnmsg;

                    if (response == "success") {

                        var grid = $("#grid_mtp").data("kendoGrid"); 

                        grid.dataSource.transport.options.read.url = "/Admin/WP_MTPs_Read?projid=" + projid + "&fyear=" + fyear + "&fperiod=" + fperiod;
                        grid.dataSource.read();

                    }
                    else if (response == "alreadyexist") {
                                dialog.kendoDialog({
                                    width: "300px",
                                    title: "Already Exist",
                                    closable: false,
                                    modal: true,
                                    content: "<p>MTP Priority Aready Exist.<p>",
                                    actions: [
                                        { text: 'Cancel' }
                                    ],
                                    close: onClose
                                });

                                dialog.data("kendoDialog").open();
                                undo.fadeOut();
                    }
                    else {

                                dialog.kendoDialog({
                                    width: "300px",
                                    title: "Error",
                                    closable: false,
                                    modal: true,
                                    content: "<p>Error: Please try Again<p>",
                                    actions: [
                                        { text: 'Cancel' }
                                    ],
                                    close: onClose
                                });

                                dialog.data("kendoDialog").open();
                                undo.fadeOut();
                    }

                },
                error: function (data) {
                                dialog.kendoDialog({
                                    width: "300px",
                                    title: "Error",
                                    closable: false,
                                    modal: true,
                                    content: "<p>Error Occurred whiles saving<p>",
                                    actions: [
                                        { text: 'Cancel' }
                                    ],
                                    close: onClose
                                });

                                dialog.data("kendoDialog").open();
                                undo.fadeOut();
                }
            })
        }
        return false;

   });
    
    
    
</script>


