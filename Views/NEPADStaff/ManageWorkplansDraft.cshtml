<script>
function editVisible(dataItem) {
// hide the Edit button for the item with ProductID=1
    return dataItem.LookUp_Status != "Transactional";
}
function onChangeContinental(e) {
   // kendoConsole.log("checked: " + e.checked);
    var projid = $("#Project_Id").val();  
    var fyear = $("#FYear").val();  
    var fperiod = $("#FPeriod").val();  
    var empid = $("#Employee_Id").val(); 
    var dirid = $("#Directorate_Id").val(); 
    var divid = $("#Division_Id").val(); 
    var progid = $("#Programme_Id").val(); 
    var contstatus="";


    var dialog = $('#dialog');
    var undo = $("#undo");

    function onClose() {
        undo.fadeIn();
    }


    if(e.checked==true){
        contstatus="True";
    }
    else{
        contstatus="False";
    }

    $.ajax({
        type: "POST",
        url: '/Admin/AddContinentalCoverage',     //your action
        data:{"projid": projid, "fyear": fyear, "fperiod": fperiod, "empid": empid, "contstatus": contstatus},
        dataType: 'json',
        success: function (result) {
            var response = result.rtnmsg;

            if (response == "nomainrecord") {
            
                dialog.kendoDialog({
                    width: "300px",
                    title: "No Outcome or MTP",
                    closable: false,
                    modal: true,
                    content: "<p>Please define at least one outcome or link an MTP Priority to the workplan<p>",
                    actions: [
                        { text: 'Cancel' }
                    ],
                    close: onClose
                });

                dialog.data("kendoDialog").open();
                undo.fadeOut();

                var switchInstance = $("#ContinentalCoverage").data("kendoSwitch");
                switchInstance.toggle();


            }
          

        },
        error: function (data) {
                        dialog.kendoDialog({
                            width: "300px",
                            title: "Error",
                            closable: false,
                            modal: true,
                            content: "<p>Error Occurred whiles saving<p>",
                            actions: [
                                { text: 'Cancel' }
                            ],
                            close: onClose
                        });

                        dialog.data("kendoDialog").open();
                        undo.fadeOut();
        }
    })
    
}

function onDataBound(e){

    var grid = $('#grid_mtp2').data('kendoGrid');

    $.each(grid.tbody.find('tr'),function(){
        var model = grid.dataItem(this);
        if(model.SelectedRow == "Selected"){
            $('[data-uid='+model.uid+']').addClass('k-state-selected').find("input").attr("checked","checked");
          //  $('[data-uid='+model.uid+']').addClass('disabled');




        }                          
    });

    var projid = $("#Project_Id").val();  
    var fyear = $("#FYear").val();  
    var fperiod = $("#FPeriod").val();  
    var empid = $("#Employee_Id").val(); 
    var dirid = $("#Directorate_Id").val(); 
    var divid = $("#Division_Id").val(); 
    var progid = $("#Programme_Id").val(); 

    var norecord = document.getElementById("norecord");
    var recordstatus = document.getElementById("recordstatus");



    $.ajax({
        type: "POST",
        url: '/Admin/CheckMainWPRecordStatus',     //your action
        //data:{"projid": projid, "fyear": fyear, "fperiod": fperiod, "selectkeys": this.selectedKeyNames().join(","), "empid": empid, selectedrows: JSON.parse( JSON.stringify(models))},
        data:{"projid": projid, "fyear": fyear, "fperiod": fperiod, "empid": empid, "dirid": dirid, "divid": divid, "progid": progid},
        dataType: 'json',
        success: function (result) {
            var response = result.rtnmsg;

            if (response == "recordfound") {
                //norecord.style.display = "none";
               // recordstatus.style.display = "block";
                norecord.style.visibility = "hidden";
                recordstatus.style.visibility = "visible";
            }
            else if(response == "norecord")
            {
                //norecord.style.display = "block";
               // recordstatus.style.display = "none";

                norecord.style.visibility = "visible";
                recordstatus.style.visibility = "hidden";
            }

        },
        error: function (data) {
                       
        }
    })



}


function onDataBoundREC(e){

    var grid = $('#grid_recs').data('kendoGrid');

    $.each(grid.tbody.find('tr'),function(){
        var model = grid.dataItem(this);
        if(model.SelectedRow == "Selected"){
            $('[data-uid='+model.uid+']').addClass('k-state-selected').find("input").attr("checked","checked");
          //  $('[data-uid='+model.uid+']').addClass('disabled');

        }                          
    });

    



}


function onDataBoundPriority(e){

    var grid = $('#gridpriority').data('kendoGrid');

    $.each(grid.tbody.find('tr'),function(){
        var model = grid.dataItem(this);
        if(model.SelectedRow == "Selected"){
            $('[data-uid='+model.uid+']').addClass('k-state-selected').find("input").attr("checked","checked");
            //$('[data-uid='+model.uid+']').addClass('disabled');
        } 
        if(model.EnableRow == "No"){
           // $('[data-uid='+model.uid+']').addClass('k-state-selected').find("input").attr("checked","checked");
          $('[data-uid='+model.uid+']').addClass('disabled');
        }                           
    });

    



}

function onChange(arg) {
   // kendoConsole.log("The selected product ids are: [" + this.selectedKeyNames().join(", ") + "]");


    var projid = $("#Project_Id").val();  
    var fyear = $("#FYear").val();  
    var fperiod = $("#FPeriod").val();  
    var empid = $("#Employee_Id").val(); 
    var dirid = $("#Directorate_Id").val(); 
    var divid = $("#Division_Id").val(); 
    var progid = $("#Programme_Id").val(); 

    var norecord = document.getElementById("norecord");
    var recordstatus = document.getElementById("recordstatus");


    var models = [];
    var gridmtp = $('#grid_mtp2').data('kendoGrid');

    var rows = gridmtp.items();

   // gridmtp.table.find("input[type=checkbox]:checked").each(function () {
   $(rows).each(function(e) {
        var row = $(this).closest("tr");
        var model = gridmtp.dataItem(row);
        models.push(model);
