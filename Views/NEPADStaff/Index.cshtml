<script type="text/javascript">

function resetpass1(e) {

        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));

        var employeeid = dataItem.Programme_Id;


        var dialog = $('#dialog');
        var undo = $("#undo");






        function onClose() {
            undo.fadeIn();
        }




        $("#windowstaff2").append("<div id='getstaffwindow2'></div>");


        var wnd3 = $("#getstaffwindow2").kendoWindow({
            //actions: ["Close"],
            draggable: true,
            modal: true,
            animation: false,
            resizable: true,
            content: "/Admin/LoginPasswordReset?employeeid=" + employeeid,
            width: 800,
            height: 370,

            title: "Reset Password",
            // close: onClose,
            deactivate: function () {
                this.destroy();
            }

        }).data("kendoWindow");
        wnd3.center().open();





    }


    function mktransactional(e) {

        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));

        var recid = dataItem.LookUp_Id;
        var recstatus= dataItem.LookUp_Status;

        var dialog = $('#dialog');
        var undo = $("#undo");

        function onClose() {
            undo.fadeIn();
        }

          if (recstatus === "" && typeof recstatus === "string") {

                            
            dialog.kendoDialog({
                  width: "450px",
                  title: "Checks",
                  closable: false,
                  modal: true,
                  content: "<p>Record has not been <strong>save</strong>.<p>",
                  actions: [
                      { text: 'OK' }
                  ],
                  close: onClose
              });

              dialog.data("kendoDialog").open();
              undo.fadeOut();
          }
          else {

              dialog.kendoDialog({
                  width: "450px",
                  title: "Confirmation",
                  closable: false,
                  modal: true,
                  content: "<p>Please <strong>confirm</strong> the action.<p>",
                  actions: [
                      {
                          text: 'Confirm',
                          action: function (e) {
                              $.ajax({
                                  type: "POST",
                                  url: '/Admin/MakeActivityTypeTrans',     //your action
                                  data: { "recid": recid},
                                  dataType: 'json',
                                  success: function (result) {
                                        var grid = $("#grid_main").data("kendoGrid"); 

                                        grid.dataSource.transport.options.read.url = "/Admin/LkUp_ActivityType_Read";
                                        grid.dataSource.read();

                                  },
                                  error: function (data) {

                                  }
                              })
                              return true;
                          },
                          primary: true

                      },
                      { text: 'Cancel' }
                  ],
                  close: onClose
              });

              dialog.data("kendoDialog").open();
              undo.fadeOut();

          }





    }







function onClick() {

    }


    </script>

