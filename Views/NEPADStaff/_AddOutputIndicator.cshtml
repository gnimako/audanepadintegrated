



@model WP_OutcomeOutputIndicatorsVM

<form id="addform">

    <input hidden asp-for="Employee_IdOIVM" class="k-textbox" style="width:100%" value="@Model.Employee_IdOIVM">
    <input hidden asp-for="Transaction_IdOIVM" class="k-textbox" style="width:100%" value="@Model.Transaction_IdOIVM">
    <input hidden asp-for="FiscalYear_IdOIVM" class="k-textbox" style="width:100%" value="@Model.FiscalYear_IdOIVM">
    <input hidden asp-for="Period_IdOIVM" class="k-textbox" style="width:100%" value="@Model.Period_IdOIVM">
    <input hidden asp-for="Project_IdOIVM" class="k-textbox" style="width:100%" value="@Model.Project_IdOIVM">
