<script>
    
    $("#btnCloseStaffa").click(function () {
        $(".k-window-content").each(function () {
            $(this).data("kendoWindow").close();
        });
    });

    $("#btnCloseStaffa_proj").click(function () {
        $(".k-window-content").each(function () {
            $(this).data("kendoWindow").close();
        });
    });

    $("#btnCloseStaffa_dir").click(function () {
        $(".k-window-content").each(function () {
            $(this).data("kendoWindow").close();
        });
    });




$("#btnSubmita").click(function (e) {

    var gridid = $("#Transaction_IdOIVM").val(); 

    var projid = $("#Project_IdOIVM").val();  
    var fyear = $("#FiscalYear_IdOIVM").val();  
    var fperiod = $("#Period_IdOIVM").val();  

    var priority= $("#Priority_IdOIVM").val();  
    var outputindicator = $("#OutputIndicator_IdOIVM").val();  

    var quantbaseline = $("#BaselineQuantitativeOIVM").val();  
    var quanttarget = $("#TargetQuantitativeOIVM").val();  
    



    if(priority === "" && typeof priority === "string")
    {
        $('#targetDivStaffa').empty();
        $('<span class="alert alert-warning" style="display: block;font-size: 100%">No Selection : Please select a strategic priority. </span>').appendTo('.rssedStaffa');
    }
    else if(outputindicator === "" && typeof outputindicator === "string")
    {
        $('#targetDivStaffa').empty();
        $('<span class="alert alert-warning" style="display: block;font-size: 100%">No Selection : Please select an indicator. </span>').appendTo('.rssedStaffa');
    }
    else{

        $.ajax({
            type: "POST",
            url: '/Admin/CheckOutputIndicatorType',     //your action
            data:{"indicatorid": outputindicator},
            //data: { selectkeys: dataItem},
            dataType: 'json',
            success: function (result) {
                var response = result.rtnmsg;

                if (response == "quantitative") {

                    if (isNaN(quantbaseline)) {
                        $('#targetDivStaffa').empty();
                        $('<span class="alert alert-warning" style="display: block;font-size: 100%">Baseline should be a number </span>').appendTo('.rssedStaffa');
                    } 
                    else if (isNaN(quanttarget)) {
                        $('#targetDivStaffa').empty();
                        $('<span class="alert alert-warning" style="display: block;font-size: 100%">Target should be a number </span>').appendTo('.rssedStaffa');
                    }
                    else if (quantbaseline==quanttarget){
                        $('#targetDivStaffa').empty();
                        $('<span class="alert alert-warning" style="display: block;font-size: 100%">Baseline and Target cannot be the same </span>').appendTo('.rssedStaffa');
                    }
                    else{
                        $.ajax({
                            type: "POST",
                            url: '/Admin/AddStrategicIndicator',     //your action
                            data: $('#addform').serialize(),   //your form name.it takes all the values of model
                            dataType: 'json',
                            success: function (result) {
                                var response = result.rtnmsg;

                                if (response == "success") {
                                            $('#targetDivStaffa').empty();
                                            $('<span class="alert alert-success" style="display: block;font-size: 100%">Success : Indicator Saved Successfully. </span>').appendTo('.rssedStaffa');


                                            var childGrid = $('#gridsub_'+gridid).data("kendoGrid");

                                            childGrid.dataSource.transport.options.read.url = "/Admin/WP_OutputsSubIndicators_Read?output_transid=" + gridid;
                                            childGrid.dataSource.read();
                                            childGrid.refresh();





                                }
                                else if (response == "pkerror") {
                                        $('#targetDivStaffa').empty();
                                        $('<span class="alert alert-danger" style="display: block;font-size: 100%">Unable to Save. Indicator Already Exist. </span>').appendTo('.rssedStaffa');
                                        //$('#targetDivStaffa').empty();
                                }
                                else if (response == "createerror") {
                                        $('#targetDivStaffa').empty();
                                        $('<span class="alert alert-danger" style="display: block;font-size: 100%">Error: Unable to save indicator</span>').appendTo('.rssedStaffa');
                                        //$('#targetDivStaffa').empty();
                                }
                                else if (response == "doesnotexist") {
                                        $('#targetDivStaffa').empty();
                                        $('<span class="alert alert-danger" style="display: block;font-size: 100%">No Record: Indicator does not exist</span>').appendTo('.rssedStaffa');
                                        //$('#targetDivStaffa').empty();
                                }
                                else {
                                        $('#targetDivStaffa').empty();
                                        $('<span class="alert alert-danger" style="display: block;font-size: 100%">Unknown Error: Please try Again </span>').appendTo('.rssedStaffa');
                                        //$('#targetDivStaffa').empty();
                                }

                            },
                            error: function (data) {
                                    $('#targetDivStaffa').empty();
                                    $('<span class="alert alert-danger" style="display: block;font-size: 100%">Error: Error Occurred whiles saving </span>').appendTo('.rssedStaffa');
                                    //$('#targetDivStaffa').empty();
                            }
                        })
                   
                    }

                }
                else
                {
                    $.ajax({
                        type: "POST",
                        url: '/Admin/AddStrategicIndicator',     //your action
                        data: $('#addform').serialize(),   //your form name.it takes all the values of model
                        dataType: 'json',
                        success: function (result) {
                            var response = result.rtnmsg;

                            if (response == "success") {
                                        $('#targetDivStaffa').empty();
                                        $('<span class="alert alert-success" style="display: block;font-size: 100%">Success : Indicator Saved Successfully. </span>').appendTo('.rssedStaffa');


                                        var childGrid = $('#gridsub_'+gridid).data("kendoGrid");

                                        childGrid.dataSource.transport.options.read.url = "/Admin/WP_OutputsSubIndicators_Read?output_transid=" + gridid;
                                        childGrid.dataSource.read();
                                        childGrid.refresh();



                            }
                            else if (response == "pkerror") {
                                    $('#targetDivStaffa').empty();
                                    $('<span class="alert alert-danger" style="display: block;font-size: 100%">Unable to Save. Indicator Already Exist. </span>').appendTo('.rssedStaffa');
                                    //$('#targetDivStaffa').empty();
                            }
                            else if (response == "createerror") {
                                    $('#targetDivStaffa').empty();
                                    $('<span class="alert alert-danger" style="display: block;font-size: 100%">Error: Unable to save indicator</span>').appendTo('.rssedStaffa');
                                    //$('#targetDivStaffa').empty();
                            }
                            else if (response == "doesnotexist") {
                                    $('#targetDivStaffa').empty();
                                    $('<span class="alert alert-danger" style="display: block;font-size: 100%">No Record: Indicator does not exist</span>').appendTo('.rssedStaffa');
                                    //$('#targetDivStaffa').empty();
                            }
                            else {
                                    $('#targetDivStaffa').empty();
                                    $('<span class="alert alert-danger" style="display: block;font-size: 100%">Unknown Error: Please try Again </span>').appendTo('.rssedStaffa');
                                    //$('#targetDivStaffa').empty();
                            }

                        },
                        error: function (data) {
                                $('#targetDivStaffa').empty();
                                $('<span class="alert alert-danger" style="display: block;font-size: 100%">Error: Error Occurred whiles saving </span>').appendTo('.rssedStaffa');
                                //$('#targetDivStaffa').empty();
                        }
                    })

                }

            },
            error: function (data) {
    
            }
        })








        
    }
    
    return false;
});


