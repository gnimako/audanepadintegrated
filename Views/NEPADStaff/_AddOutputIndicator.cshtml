                                <br />
                                <br />
                                <br />
                                <h5 style="color:#807878"> Target </h5>
                                @Html.TextAreaFor(model => model.TargetQuanlitativeOIVM_Dir, new { @class = "k-textbox", style = "width: 100%;",  value="", rows="3"})
                            </div>
                            <br />
                            <div id="targetDivStaffa_dir" class="rssedStaffa_dir">
                            </div>
                            <br />
                            <br />
                            <div style="align-content:center; text-align:center">
                                <a class="k-button" id="btnSubmita_dir">
                                    <span class="k-icon k-i-save"></span> Save
                                </a>

                                <a class="k-button" id="btnCloseStaffa_dir">
                                    <span class="k-icon k-i-cancel"></span> Close
                                </a>
                            </div>

                        </div>
                  </text>);


 tabstrip.Add().Text("Institutional Level Indicators")
                  .Content(@<text>
                        <div>
                            <br />
                            <br />
                            @(Html.Kendo().DropDownListFor(model => model.Priority_IdOIVM)
                                // .Name("Department_Id")
                                .HtmlAttributes(new { style = "width:100%", id = "Priority_IdOIVM" })
                                .OptionLabel("Select Strategic Priority...")
                                .DataTextField("DropDown_Name")
                                .DataValueField("DropDown_IntId")
                                .DataSource(source =>
                                {
                                    source.Read(read =>
                                    {
                                            read.Action("GetWPStrategicPriorities", "Admin", new {projid=Model.Project_IdOIVM, fyear=Model.FiscalYear_IdOIVM, fperiod=Model.Period_IdOIVM, mainrecid=Model.WPMainRecord_idOIVM});
                                        
                                    })
                                    .ServerFiltering(true);
                                })
                            
                                //.SelectedIndex(Model.Department_Id)
                            )
                            <br />
                            <br />
                            <br />

                            @(Html.Kendo().DropDownListFor(model => model.OutputIndicator_IdOIVM)
                                    // .Name("Department_Id")
                                    .HtmlAttributes(new { style = "width:100%", id = "OutputIndicator_IdOIVM" })
                                    .OptionLabel("Select Indicator...")
                                    .DataTextField("DropDown_Name")
                                    .DataValueField("DropDown_IntId")
                                    .Events(e =>
                                    {
                                            e.Close("onDropDownChangeOutputIndicator");
                                    })
                                    .DataSource(source =>
                                    {
                                        source.Read(read =>
                                        {
                                                read.Action("GetTransOutputIndicatorsByPriority", "Admin")
                                                .Data("filterindicators");
                                        })
                                        .ServerFiltering(true);
                                    })
                                    .Enable(false)
                                    .AutoBind(false)
                                    .CascadeFrom("Priority_IdOIVM")
                                    //.SelectedIndex(Model.Department_Id)
                            )


                            <br />
                            <br />
                            <br />
                            
                            <div id="quantitativediv">
                                <h5 style="color:#807878"> Baseline </h5>
                                @Html.TextAreaFor(model => model.BaselineQuantitativeOIVM, new { @class = "k-textbox",  style = "width: 100%;", value="", rows="3"})
                                <br />
                                <br />
                                <br />
                                <h5 style="color:#807878"> Target </h5>
                                @Html.TextAreaFor(model => model.TargetQuantitativeOIVM, new { @class = "k-textbox", style = "width: 100%;",  value="", rows="3"})
                            </div>

                            <div id="qualitativediv" hidden>
                                <h5 style="color:#807878"> Baseline </h5>
                                @Html.TextAreaFor(model => model.BaselineQuanlitativeOIVM, new { @class = "k-textbox", style = "width: 100%;", value="", rows="3"})
                                <br />
                                <br />
                                <br />
                                <h5 style="color:#807878"> Target </h5>
                                @Html.TextAreaFor(model => model.TargetQuanlitativeOIVM, new { @class = "k-textbox", style = "width: 100%;",  value="", rows="3"})
                            </div>
                            <br />
                            <div id="targetDivStaffa" class="rssedStaffa">
                            </div>
                            <br />
                            <br />
                            <div style="align-content:center; text-align:center">
                                <a class="k-button" id="btnSubmita">
                                    <span class="k-icon k-i-save"></span> Save
                                </a>

                                <a class="k-button" id="btnCloseStaffa">
                                    <span class="k-icon k-i-cancel"></span> Close
                                </a>
                            </div>

                        </div>
