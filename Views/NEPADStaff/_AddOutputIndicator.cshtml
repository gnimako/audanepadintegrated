                                <br />
                                <br />
                                <br />
                                <h5 style="color:#807878"> Target </h5>
                                @Html.TextAreaFor(model => model.TargetQuanlitativeOIVM_Proj, new { @class = "k-textbox", style = "width: 100%;",  value="", rows="3"})
                            </div>
                            <br />
                            <div id="targetDivStaffa_proj" class="rssedStaffa_proj">
                            </div>
                            <br />
                            <br />
                            <div style="align-content:center; text-align:center">
                                <a class="k-button" id="btnSubmita_proj">
                                    <span class="k-icon k-i-save"></span> Save
                                </a>

                                <a class="k-button" id="btnCloseStaffa_proj">
                                    <span class="k-icon k-i-cancel"></span> Close
                                </a>
                            </div>
                    </div>
                    <span class="">&nbsp;</span>
                  </text>);

tabstrip.Add().Text("Directorate Level Indicators")
                  .Content(@<text>
                        <div>
                        <br />
                        <br />
                          @(Html.Kendo().DropDownListFor(model => model.IndicatorIDOIVM_Dir)
                                // .Name("Department_Id")
                                .HtmlAttributes(new { style = "width:100%", id = "IndicatorIDOIVM_Dir" })
                                .OptionLabel("Select Indicator...")
                                .DataTextField("DropDown_Name")
                                .DataValueField("DropDown_IntId")
                                .Events(e =>
                                {
                                        e.Close("onDropDownChangeOutputIndicator_Dir");
                                })
